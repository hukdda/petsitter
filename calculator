<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>실시간 견적 계산기 - 펫시터의 정석</title>
    
    <style>
        body, h1, h2, p, a, select, input, button { margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; box-sizing: border-box; }
        body { background-color: #fdfdfd; color: #333; }
        .container { max-width: 960px; margin: 0 auto; padding: 0 20px; }
        header { padding: 20px 0; border-bottom: 1px solid #eee; background-color: #fff; }
        header h1 { text-align: center; font-size: 28px; }
        header h1 a { text-decoration: none; color: #2c3e50; }
        header nav { text-align: center; margin-top: 10px; }
        header nav a { margin: 0 15px; text-decoration: none; color: #3498db; font-weight: 500; }
        .calculator-section { padding: 50px 0; text-align: center; }
        .calculator-section h2 { font-size: 32px; margin-bottom: 10px; }
        .calculator-section p { font-size: 18px; color: #777; }
        .calculator-form { max-width: 600px; margin: 40px auto; text-align: left; background: #ffffff; padding: 40px; border-radius: 12px; box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08); }
        .form-group { margin-bottom: 25px; }
        .form-group label { display: block; font-weight: 600; margin-bottom: 10px; font-size: 16px; }
        .form-group select, .form-group input { width: 100%; padding: 15px; border: 1px solid #ddd; border-radius: 8px; font-size: 16px; background-color: #f9f9f9; }
        .form-group select:focus, .form-group input:focus { outline: none; border-color: #3498db; background-color: #fff; }
        .price-display { margin-top: 40px; padding: 25px; background: #f0f7ff; border: 1px dashed #3498db; border-radius: 8px; text-align: center; }
        .price-display .label { font-size: 16px; color: #555; }
        .price-display .amount { font-size: 42px; font-weight: 700; color: #2c3e50; display: block; margin: 8px 0; }
        .price-display .currency { font-size: 22px; color: #2c3e50; margin-left: 5px; }
        .price-display .details { font-size: 15px; color: #667788; margin-top: 12px; min-height: 22px; }
        .cta-button { width: 100%; padding: 18px; font-size: 18px; font-weight: 600; color: #fff; background-color: #3498db; border: none; border-radius: 8px; cursor: pointer; transition: background-color 0.3s, transform 0.1s; }
        .cta-button:hover { background-color: #2980b9; }
        .cta-button:active { transform: scale(0.99); }
        .cta-button:disabled { background-color: #bdc3c7; cursor: not-allowed; }
        footer { text-align: center; padding: 40px 0; margin-top: 50px; border-top: 1px solid #eee; color: #999; }
    </style>
</head>
<body>

    <header>
        <div class="container">
            <h1><a href="index.html">펫시터의 정석</a></h1>
            <nav>
                <a href="index.html">홈</a>
                <a href="calculator.html">실시간 견적</a>
            </nav>
        </div>
    </header>

    <main>
        <section class="calculator-section">
            <div class="container">
                <h2>실시간 견적 계산기</h2>
                <p>간단한 정보 입력으로 예상 비용을 바로 확인해보세요.</p>

                <div class="calculator-form">
                    <div class="form-group">
                        <label for="service">서비스 종류</label>
                        <select id="service">
                            <option value="0" data-price="0">-- 서비스를 선택해주세요 --</option>
                            <option value="1" data-price="25000">방문돌봄 30분</option>
                            <option value="2" data-price="30000">방문돌봄 60분</option>
                            <option value="3" data-price="35000">산책 포함 60분</option>
                            <option value="4" data-price="45000">산책 포함 120분</option>
                            <option value="5" data-price="15000">목욕 (추가 서비스)</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="start-date">방문 시작일</label>
                        <input type="date" id="start-date">
                    </div>

                    <div class="form-group">
                        <label for="end-date">방문 종료일</label>
                        <input type="date" id="end-date">
                    </div>
                    
                    <div class="form-group">
                        <label for="pet-count">반려동물 수</label>
                        <select id="pet-count">
                            <option value="1" data-surcharge="0">1마리 (추가금 없음)</option>
                            <option value="2" data-surcharge="5000">2마리 (+5,000원)</option>
                            <option value="3" data-surcharge="10000">3마리 (+10,000원)</option>
                        </select>
                    </div>

                    <div class="price-display">
                        <span class="label">예상 비용</span>
                        <span class="amount">0</span><span class="currency">원</span>
                        <div class="details">서비스를 선택해주세요.</div>
                    </div>

                    <button id="submit-booking" class="cta-button">
                        <span>예약 정보 입력하기</span>
                    </button>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <div class="container">
            <p>&copy; 2025 펫시터의 정석. All Rights Reserved.</p>
        </div>
    </footer>

    <script>
    document.addEventListener('DOMContentLoaded', () => {
        
        const serviceSelect = document.getElementById('service');
        const startDateInput = document.getElementById('start-date');
        const endDateInput = document.getElementById('end-date');
        const petCountSelect = document.getElementById('pet-count');
        const amountDisplay = document.querySelector('.price-display .amount');
        const detailsDisplay = document.querySelector('.price-display .details');
        const submitButton = document.getElementById('submit-booking');
        const tallyFormUrl = 'https://tally.so/r/Pdp5qx';

        function calculatePrice( ) {
            const selectedService = serviceSelect.options[serviceSelect.selectedIndex];
            const basePrice = parseInt(selectedService.dataset.price || '0', 10);
            let serviceText = selectedService.text;

            const startDate = new Date(startDateInput.value);
            const endDate = new Date(endDateInput.value);
            let visitDays = 0;
            if (startDateInput.value && endDateInput.value && endDate >= startDate) {
                visitDays = Math.round((endDate - startDate) / (1000 * 60 * 60 * 24)) + 1;
            }

            const selectedPet = petCountSelect.options[petCountSelect.selectedIndex];
            const petSurcharge = parseInt(selectedPet.dataset.surcharge || '0', 10);
            let petText = selectedPet.text;

            let finalPrice = 0;
            let detailsText = '서비스와 방문일을 모두 선택해주세요.';

            if (basePrice > 0) {
                if (serviceText.includes('목욕')) {
                    finalPrice = basePrice + petSurcharge;
                    detailsText = `(${serviceText})`;
                     if (petSurcharge > 0) {
                        detailsText += ` + (${petText})`;
                    }
                } 
                else if (visitDays > 0) {
                    finalPrice = (basePrice + petSurcharge) * visitDays;
                    detailsText = `(${serviceText}) x ${visitDays}일`;
                    if (petSurcharge > 0) {
                        detailsText += ` + (${petText})`;
                    }
                } else {
                    detailsText = '방문일을 선택해주세요.';
                }
            } else {
                detailsText = '서비스를 선택해주세요.';
            }

            amountDisplay.textContent = finalPrice.toLocaleString();
            detailsDisplay.textContent = detailsText;
        }

        serviceSelect.addEventListener('change', calculatePrice);
        startDateInput.addEventListener('change', calculatePrice);
        endDateInput.addEventListener('change', calculatePrice);
        petCountSelect.addEventListener('change', calculatePrice);

        submitButton.addEventListener('click', (e) => {
            e.preventDefault();

            const finalPrice = amountDisplay.textContent.replace(/,/g, '');
            const priceDetails = detailsDisplay.textContent;

            if (parseInt(finalPrice, 10) <= 0) {
                alert('서비스와 방문일을 선택하여, 먼저 예상 비용을 계산해주세요!');
                return;
            }

            const params = new URLSearchParams();
            params.append('price', finalPrice);
            params.append('details', priceDetails);
            params.append('service', serviceSelect.options[serviceSelect.selectedIndex].text);
            params.append('startDate', startDateInput.value);
            params.append('endDate', endDateInput.value);
            params.append('pets', petCountSelect.options[petCountSelect.selectedIndex].text);

            const finalUrl = `${tallyFormUrl}?${params.toString()}`;

            submitButton.querySelector('span').textContent = '예약 페이지로 이동 중...';
            submitButton.disabled = true;

            setTimeout(() => {
                window.location.href = finalUrl;
            }, 300);
        });

        calculatePrice();
    });
    </script>

</body>
</html>
